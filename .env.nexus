# NEXUS Platform Environment
# Copy to .env before running docker compose

NEXUS_PORT=3080

# Google OAuth (copy from your Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Secret key (generate: openssl rand -base64 32)
WEBUI_SECRET_KEY=change-me-generate-a-real-secret
